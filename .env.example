# ── Backend (.env) ────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
DB_NAME=hotstylevideo_site          # scraper DB name (site_name())
COLLECTION=video_urls               # MongoDB collection jisme video URLs hain
PORT=4000
API_TOKEN=change-this-to-secret     # Bearer token (optional lekin recommended)
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# ── Frontend (.env) ────────────────────────────────────────
VITE_SITE_NAME=HotStyleVideo        # Header mein dikhega
VITE_API_TOKEN=change-this-to-secret
